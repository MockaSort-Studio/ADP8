bazel_dep(name = "asio", version = "1.34.2.bcr.0")

###
bazel_dep(name = "cmake_configure_file", version = "0.1.6")

fastddsgen_ext = use_extension("//:third_party/fastddsgen/extensions.bzl", "fastddsgen")
