###### FASTDDS and FASTDDS GEN ######
##
# 3.4.2: pure cc_library build — no cmake(), no PIC patch needed.
# -stdlib=libc++ propagates automatically via .bazelrc --cxxopt.
bazel_dep(name = "fastdds", version = "3.4.2")

##
bazel_dep(name = "fastcdr", version = "2.3.5.bcr.0")
bazel_dep(name = "foonathan_memory", version = "0.7.3.bcr.2")
bazel_dep(name = "tinyxml2", version = "10.0.0")
bazel_dep(name = "asio", version = "1.34.2.bcr.0")
bazel_dep(name = "openssl", version = "3.5.5.bcr.0")
bazel_dep(name = "sqlite3", version = "3.51.2")
bazel_dep(name = "nlohmann_json", version = "3.12.0.bcr.1")
bazel_dep(name = "rules_perl", version = "0.5.0")
# bazel_dep(name = "rules_java", version = "9.6.1")

###
bazel_dep(name = "cmake_configure_file", version = "0.1.6")

fastddsgen_ext = use_extension("//:third_party/fastddsgen/extensions.bzl", "fastddsgen")
use_repo(fastddsgen_ext, "fastddsgen")

###### LLVM toolchain + sysroot ######
