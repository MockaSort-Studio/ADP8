# cpp 17 + hermetic libc++ (toolchains_llvm clang 19)
build --cxxopt=-std=c++17
build --cxxopt=-stdlib=libc++
build --linkopt=-stdlib=libc++
build --linkopt=-lc++abi
build --nostart_end_lib

# hermetic interpreter Python 3.14
# Use the modern bootstrap that doesn't rely on a system 'python3' to start
build --@rules_python//python/config_settings:bootstrap_impl=script
# Ensure we never "leak" into the system interpreter
build --incompatible_use_python_toolchains
build --incompatible_default_to_explicit_init_py

#local build with remote cache
build:remote --bes_results_url=https://app.buildbuddy.io/invocation/
build:remote --bes_backend=grpcs://remote.buildbuddy.io
build:remote --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
common:remote --remote_cache=grpcs://remote.buildbuddy.io
common:remote --noremote_upload_local_results
common:remote --remote_timeout=10m
common:remote --remote_cache_compression

#ci build with remote cache and RBE
build:ci --config=remote
build:ci --platforms=@toolchains_llvm//platforms:linux-x86_64
build:ci --build_metadata=ROLE=CI
build:ci --remote_executor=grpcs://remote.buildbuddy.io
build:ci --jobs=20

build:ci --remote_default_exec_properties=container-image=docker://ubuntu:22.04

#FastDDSGen runtime
common:ci --java_language_version=17
common:ci --tool_java_language_version=17
common:ci --java_runtime_version=remotejdk_17
common:ci --tool_java_runtime_version=remotejdk_17
#ci config for main branch build that will keep the remote cache up to date
build:main --config=ci
build:main --remote_upload_local_results


try-import %workspace%/.bazelrc.user